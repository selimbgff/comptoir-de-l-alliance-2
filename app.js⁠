const catalog = [
    { name: "Alliance Platine", price: "1200 €", img: "https://picsum.photos/400/400?1" },
    { name: "Alliance Diamant", price: "1500 €", img: "https://picsum.photos/400/400?2" },
    { name: "Alliance Or Rose", price: "1100 €", img: "https://picsum.photos/400/400?3" },
    { name: "Alliance Or Jaune", price: "950 €", img: "https://picsum.photos/400/400?4" }
];

const grid = document.getElementById('catalog');
grid.innerHTML = catalog.map(item => `
    <div class="product-card">
        <img src="${item.img}" alt="${item.name}">
        <h3>${item.name}</h3>
        <p>${item.price}</p>
        <a href="#" class="btn">Commander</a>
    </div>
`).join('');
